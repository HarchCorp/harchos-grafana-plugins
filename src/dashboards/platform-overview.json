    {
      "datasource": { "type": "harchos-datasource", "uid": "${DS_HARCHOS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 6,
      "options": {
        "displayMode": "table",
        "groupBy": "hub",
        "showCpu": true,
        "showMemory": true,
        "showTaskCounts": true,
        "showEnergyPerWorkload": true,
        "maxWorkloads": 20,
        "colorScheme": "harchos"
      },
      "pluginVersion": "1.0.0",
      "targets": [
        {
          "datasource": { "type": "harchos-datasource", "uid": "${DS_HARCHOS}" },
          "expr": "harchos_workload_cpu_usage_cores{job=\"harchos-workload\"}",
          "language": "promql",
          "legendFormat": "{{workload_name}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "harchos-datasource", "uid": "${DS_HARCHOS}" },
          "expr": "harchos_workload_energy_kwh{job=\"harchos-workload\"}",
          "language": "energyql",
          "legendFormat": "{{workload_name}}",
          "refId": "B"
        }
      ],
      "title": "Active Workloads",
      "type": "harchos-workload-distribution-panel"
    },
    {
      "datasource": { "type": "harchos-datasource", "uid": "${DS_HARCHOS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 7,
      "options": {
        "displayMode": "breakdown",
        "carbonUnit": "g",
        "showEnergy": true,
        "showCost": false,
        "energyPricePerKwh": 0.12,
        "carbonIntensityFactor": 475,
        "showTrend": true,
        "sustainabilityTarget": 0
