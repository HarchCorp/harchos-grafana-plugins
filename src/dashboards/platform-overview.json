      "pluginVersion": "1.0.0",
      "targets": [
        {
          "datasource": { "type": "harchos-datasource", "uid": "${DS_HARCHOS}" },
          "expr": "harchos_gpu_hourly_price{job=\"harchos-pricing\"}",
          "language": "energyql",
          "legendFormat": "{{region_name}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "harchos-datasource", "uid": "${DS_HARCHOS}" },
          "expr": "carbon_intensity_gco2_kwh{job=\"harchos-carbon\"}",
          "language": "energyql",
          "legendFormat": "{{region_name}}",
          "refId": "B"
        }
      ],
      "title": "GPU Pricing Comparison",
      "type": "harchos-pricing-comparison-panel"
