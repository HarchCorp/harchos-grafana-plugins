    },
    "keywords": ["harchos", "carbon", "forecast", "green", "intensity", "energy"],
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "links": [
      {
        "name": "Documentation",
        "url": "https://docs.harchcorp.io/harchos/grafana-plugins/carbon-forecast",
        "type": "docs"
      }
    ],
    "version": "1.0.0",
    "updated": "%DATE%"
  },
  "dependencies": {
    "grafanaDependency": ">=10.0.0",
    "plugins": []
  }
}
